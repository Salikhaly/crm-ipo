# ═══════════════════════════════════════════════════
# Mortgage CRM — переменные окружения
# Скопируйте этот файл в .env.local и заполните значения
# НИКОГДА не коммитьте .env.local в git
# ═══════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT Auth (ОБЯЗАТЕЛЬНО: минимум 32 случайных символа) ──
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars!!

# ── Green API (WhatsApp) ────────────────────────────
GREEN_API_ID=1234567890
GREEN_API_TOKEN=your-green-api-token-here

# ── Webhook Security (ОБЯЗАТЕЛЬНО) ──────────────────
# Генерация: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# Добавьте этот секрет в Green API консоли:
# Settings → Notifications → Webhook URL:
# https://your-site.vercel.app/api/wa/webhook?secret=ВАШ_СЕКРЕТ
WEBHOOK_SECRET=your-webhook-secret-here

# ── Next.js ─────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# ── Google Drive ─────────────────────────────────────
# 1. Создайте Service Account в Google Cloud Console
# 2. Скачайте JSON-ключ
# 3. Вставьте содержимое JSON одной строкой (без переносов):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"crm-drive-bot@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ID корневой папки в Google Drive (из URL папки "CRM — Клиенты")
# https://drive.google.com/drive/folders/ВОТ_ЭТОТ_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=1ABC123xyzYourFolderIdHere
